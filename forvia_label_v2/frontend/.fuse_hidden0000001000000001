<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forvia 标注 v2</title>
  <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/dist/ag-grid-community.min.js"></script>
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/styles/ag-grid.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/styles/ag-theme-quartz.css" />
  <style>
    :root { --bd:#e3e6ea; --fg:#1f2329; --mut:#6b7280; --acc:#2563eb; }
    * { box-sizing: border-box; }
    body { margin:0; font-family: system-ui,-apple-system,"Segoe UI","PingFang SC",sans-serif; color:var(--fg); }
    header { padding:12px 18px; border-bottom:1px solid var(--bd); display:flex; align-items:center; gap:16px; }
    header h1 { font-size:16px; margin:0; }
    .tabs { display:flex; gap:6px; margin-left:auto; }
    .tab { padding:6px 14px; border:1px solid var(--bd); border-radius:8px; cursor:pointer; background:#fff; font-size:13px; }
    .tab.active { background:var(--acc); color:#fff; border-color:var(--acc); }
    .wrap { padding:14px 18px; }
    .toolbar { display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-bottom:10px; }
    .toolbar label { font-size:13px; color:var(--mut); display:flex; gap:5px; align-items:center; }
    select, button.btn { padding:5px 9px; border:1px solid var(--bd); border-radius:7px; font-size:13px; background:#fff; cursor:pointer; }
    button.btn[disabled] { opacity:.4; cursor:default; }
    .btn.primary { background:var(--acc); color:#fff; border-color:var(--acc); }
    .stats { margin-left:auto; font-size:13px; color:var(--mut); }
    .stats b { color:var(--fg); }
    .badge { font-size:11px; padding:1px 7px; border-radius:99px; background:#fff7ed; color:#c2410c; border:1px solid #fed7aa; }
    #grid { width:100%; height: calc(100vh - 170px); }
    .hint { font-size:12px; color:var(--mut); margin-top:6px; }
    /* 标注视图 */
    .navbar { display:flex; align-items:center; gap:12px; padding:10px 18px; border-bottom:1px solid var(--bd); position:sticky; top:0; background:#fff; z-index:5; }
    .progress { flex:1; }
    .progress .bar { height:10px; border-radius:99px; background:#eef0f2; overflow:hidden; }
    .progress .bar > i { display:block; height:100%; background:var(--acc); }
    .progress .lab { font-size:12px; color:var(--mut); margin-bottom:3px; }
    .meta { padding:10px 18px; font-size:14px; display:flex; gap:18px; flex-wrap:wrap; align-items:center; border-bottom:1px solid var(--bd); }
    .meta .k { color:var(--mut); margin-right:4px; }
    .star { color:#d97706; }
    .cards { padding:8px 18px 40px; }
    .card { border:1px solid var(--bd); border-radius:10px; margin:12px 0; overflow:hidden; }
    .card-h { padding:8px 12px; font-size:13px; font-weight:600; border-bottom:1px solid var(--bd); background:#fafbfc; }
    .plot { width:100%; }
    audio { width:100%; margin:6px 0 2px; }
    .placeholder { margin:14px 18px; padding:14px; border:1px dashed var(--bd); border-radius:10px; color:var(--mut); font-size:13px; }
    .loading { padding:30px; text-align:center; color:var(--mut); }
    /* 多通道并列 */
    .channels-row { display:flex; gap:16px; padding:8px 18px 40px; align-items:flex-start; }
    .channel-col { flex:1 1 0; min-width:0; }
    .ch-head { font-weight:600; font-size:14px; padding:8px 4px; display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .tag { font-size:11px; padding:1px 8px; border-radius:99px; border:1px solid var(--bd); color:var(--mut); background:#fff; }
    .tag.ok { color:#15803d; border-color:#bbf7d0; background:#f0fdf4; }
    .tag.star { color:#d97706; border-color:#fed7aa; background:#fff7ed; }
    /* 参数调整面板 */
    .param-panel { background:#f7f8fa; border-bottom:1px solid var(--bd); }
    .param-panel-h { font-size:12px; font-weight:600; color:var(--fg); padding:7px 12px 0; }
    .param-grid { padding:8px 12px 10px; display:flex; gap:14px; flex-wrap:wrap; align-items:flex-end; }
    .param-item { font-size:12px; color:var(--mut); display:flex; flex-direction:column; gap:3px; }
    .param-item select, .param-item input { padding:4px 8px; border:1px solid var(--bd); border-radius:6px; min-width:90px; }
    /* 初始化表单 */
    .field { margin:12px 0; }
    .field > label { display:block; font-size:13px; color:var(--fg); margin-bottom:5px; }
    .row { display:flex; gap:8px; }
    .row input[type=text] { flex:1; padding:7px 10px; border:1px solid var(--bd); border-radius:7px; font-size:13px; }
    .row.drag { outline:2px dashed var(--acc); outline-offset:3px; border-radius:8px; background:#eef2ff; }
    /* 文件浏览器 */
    .modal-mask { position:fixed; inset:0; background:rgba(0,0,0,.35); display:flex; align-items:center; justify-content:center; z-index:50; }
    .modal { width:620px; max-height:78vh; background:#fff; border-radius:12px; display:flex; flex-direction:column; overflow:hidden; }
    .modal-h { display:flex; align-items:center; gap:8px; padding:12px 14px; border-bottom:1px solid var(--bd); font-weight:600; font-size:14px; }
    .modal-roots { display:flex; gap:6px; flex-wrap:wrap; padding:8px 14px; border-bottom:1px solid var(--bd); }
    .chip { font-size:12px; padding:3px 9px; border:1px solid var(--bd); border-radius:99px; cursor:pointer; background:#fff; }
    .chip:hover { background:#eef2ff; }
    .modal-path { padding:8px 14px; font-size:12px; color:var(--mut); background:#f7f8fa; word-break:break-all; }
    .modal-list { overflow:auto; padding:6px 8px; flex:1; min-height:240px; }
    .modal-list .item { padding:7px 10px; border-radius:7px; cursor:pointer; font-size:13px; }
    .modal-list .item:hover { background:#eef2ff; }
    .modal-list .file { color:#2563eb; }
    .modal-f { display:flex; align-items:center; gap:10px; padding:10px 14px; border-top:1px solid var(--bd); }
  </style>
</head>
<body>
<div id="app">
  <header>
    <h1>🎧 Forvia 标注 v2</h1>
    <span v-if="isMock" class="badge">演示数据（未配置 sample_view / tdms）</span>
    <div class="tabs">
      <div class="tab" :class="{active: view==='init'}" @click="view='init'">📂 数据源</div>
      <div class="tab" :class="{active: view==='list'}" @click="view='list'">📋 列表总览</div>
      <div class="tab" :class="{active: view==='label'}" @click="view='label'">🎧 逐条标注</div>
      <div class="tab" :class="{active: view==='task'}" @click="openTasks">🛠 任务</div>
    </div>
  </header>

  <!-- ===== 任务 ===== -->
  <div v-show="view==='task'" class="wrap" style="max-width:920px">
    <div class="card" style="padding:16px;margin-bottom:14px">
      <h3 style="margin:0 0 12px">创建任务</h3>
      <div style="display:flex;gap:14px;flex-wrap:wrap;align-items:flex-end">
        <label style="font-size:13px;color:var(--mut);display:flex;flex-direction:column;gap:4px">任务类型
          <select v-model="taskForm.task_id" @change="onTaskTypeChange" style="padding:6px 9px;border:1px solid var(--bd);border-radius:7px;min-width:220px">
            <option v-for="t in taskTypes" :key="t.id" :value="t.id">{{ t.title }}</option>
          </select>
        </label>
        <label style="font-size:13px;color:var(--mut);display:flex;flex-direction:column;gap:4px">范围
          <select v-model="taskForm.scope" style="padding:6px 9px;border:1px solid var(--bd);border-radius:7px">
            <option value="all">全部样本</option>
            <option v-for="l in lines" :key="l" :value="l">线 {{ l }}</option>
          </select>
        </label>
        <label v-for="p in currentTaskParams" :key="p.key" style="font-size:13px;color:var(--mut);display:flex;flex-direction:column;gap:4px">{{ p.label }}
          <select v-if="p.type==='select'" v-model="taskForm.params[p.key]" style="padding:6px 9px;border:1px solid var(--bd);border-radius:7px">
            <option v-for="o in p.options" :key="o" :value="o">{{ o }}</option>
          </select>
          <input v-else type="number" v-model.number="taskForm.params[p.key]" :min="p.min" :max="p.max" :step="p.step"
                 style="width:100px;padding:6px 9px;border:1px solid var(--bd);border-radius:7px" />
        </label>
        <button class="btn primary" @click="runTask">▶ 执行任务</button>
      </div>
    </div>

    <div class="card" style="padding:16px">
      <div style="display:flex;align-items:center"><h3 style="margin:0">任务运行</h3>
        <button class="btn" style="margin-left:auto" @click="loadRuns">↻ 刷新</button></div>
      <table style="width:100%;border-collapse:collapse;font-size:13px;margin-top:10px">
        <thead><tr style="text-align:left;color:var(--mut)">
          <th style="padding:6px">任务</th><th>范围</th><th>状态</th><th>进度</th><th>结果</th><th>建议</th><th>时间</th>
        </tr></thead>
        <tbody>
          <tr v-for="r in runs" :key="r.run_id" style="border-top:1px solid var(--bd)">
            <td style="padding:6px">{{ r.task_title }}</td><td>{{ r.scope }}</td>
            <td><span class="tag" :class="{ok:r.status==='done'}">{{ r.status }}</span></td>
            <td style="min-width:120px">
              <div class="bar" style="height:8px"><i :style="{width:(r.total?Math.round(r.done/r.total*100):0)+'%'}"></i></div>
              {{ r.done }}/{{ r.total }}
            </td>
            <td>{{ r.n_results }}</td><td>{{ r.n_suggestions }}</td><td style="color:var(--mut)">{{ r.started }}</td>
          </tr>
          <tr v-if="!runs.length"><td colspan="7" style="padding:10px;color:var(--mut)">暂无任务运行</td></tr>
        </tbody>
      </table>
      <p class="hint" style="margin-top:8px">建议标签不直接入库；进入"逐条标注"在对应通道点"采纳"才写入 label_history（source=model）。</p>
    </div>
  </div>

  <!-- ===== 数据源 / 初始化 ===== -->
  <div v-show="view==='init'" class="wrap" style="max-width:680px">
    <div class="card" style="padding:18px">
      <h3 style="margin:0 0 14px">加载数据</h3>
      <p class="hint" style="margin:-6px 0 10px">可把文件/文件夹从访达拖到对应输入框（浏览器无法读取文件夹路径时请用"选择…"）。</p>
      <div class="field">
        <label>① sample_view.csv</label>
        <div class="row" :class="{drag: dragTarget==='sv'}"
             @dragover.prevent="dragTarget='sv'" @dragleave="dragTarget=''" @drop.prevent="onDrop($event,'sv')">
          <input type="text" v-model="initForm.sample_view_path" placeholder="点击选择 / 粘贴 / 拖入路径" />
          <button class="btn" @click="openPicker('sv')">选择…</button>
        </div>
      </div>
      <div class="field">
        <label>② TDMS 存放目录（.tdms / .tdms.zst）</label>
        <div class="row" :class="{drag: dragTarget==='tdms'}"
             @dragover.prevent="dragTarget='tdms'" @dragleave="dragTarget=''" @drop.prevent="onDrop($event,'tdms')">
          <input type="text" v-model="initForm.tdms_root" placeholder="点击选择 / 粘贴 / 拖入目录" />
          <button class="btn" @click="nativeDir('tdms')">选择…</button>
        </div>
      </div>
      <div class="field">
        <label><input type="checkbox" v-model="initForm.loadLabels" /> ③ 加载数据库文件夹（可选）</label>
        <div class="row" v-if="initForm.loadLabels" :class="{drag: dragTarget==='label'}"
             @dragover.prevent="dragTarget='label'" @dragleave="dragTarget=''" @drop.prevent="onDrop($event,'label')">
          <input type="text" v-model="initForm.sample_records_db_path" placeholder="选择数据库文件夹（自动找 sample_records.db / tdms_manifest.csv）" />
          <button class="btn" @click="nativeDir('label')">选择…</button>
        </div>
        <p v-if="initForm.loadLabels" class="hint" style="margin:4px 0 0">自动在该文件夹及其 metadata/ 下查找 sample_records.db（历史标签）与 tdms_manifest.csv（tdms 登记）。</p>
      </div>
      <div class="field">
        <label>标注来源 source</label>
        <select v-model="initForm.source" style="padding:7px 10px;border:1px solid var(--bd);border-radius:7px;min-width:160px">
          <option value="expert">expert（专家）</option>
          <option value="operator">operator（作业员）</option>
        </select>
      </div>
      <div style="margin-top:14px; display:flex; gap:10px; align-items:center">
        <button class="btn primary" @click="doInit" :disabled="initing">{{ initing ? '加载中…' : '加载并开始标注' }}</button>
        <span v-if="initMsg" :style="{color: initErr ? '#b91c1c' : 'var(--mut)'}">{{ initMsg }}</span>
      </div>
      <p class="hint" style="margin-top:12px">不选择时使用内置演示数据。不勾选③则从空标签开始。单通道输入会自动补齐该 tdms 的 up/down，并在列表"输入"列标出原始输入样本。</p>
    </div>

    <!-- 输入样表 -->
    <div class="card" style="padding:16px;margin-top:14px">
      <h3 style="margin:0 0 6px;font-size:15px">输入样表（sample_view.csv 扩展版）</h3>
      <p class="hint" style="margin:0 0 10px">至少包含 <b>view_name / line / sn / sample_id</b>；可带标注信息(reason_name 等)与 relative_path/tdms_path。原有列都会被保留。</p>
      <div style="overflow:auto">
        <table style="border-collapse:collapse;font-size:12px;white-space:nowrap">
          <thead><tr style="color:var(--mut);text-align:left">
            <th style="padding:4px 8px;border-bottom:1px solid var(--bd)">view_name</th>
            <th style="padding:4px 8px;border-bottom:1px solid var(--bd)">line</th>
            <th style="padding:4px 8px;border-bottom:1px solid var(--bd)">sn</th>
            <th style="padding:4px 8px;border-bottom:1px solid var(--bd)">sample_id</th>
            <th style="padding:4px 8px;border-bottom:1px solid var(--bd)">reason_name</th>
            <th style="padding:4px 8px;border-bottom:1px solid var(--bd)">relative_path (可选)</th>
          </tr></thead>
          <tbody style="color:var(--fg)">
            <tr><td style="padding:4px 8px">epump2_v1</td><td style="padding:4px 8px">epump2</td><td style="padding:4px 8px">HI4B0620</td><td style="padding:4px 8px">HI4B0620_up</td><td style="padding:4px 8px">正常</td><td style="padding:4px 8px;color:var(--mut)">epump2/2026.../HI4B0620....tdms.zst</td></tr>
            <tr><td style="padding:4px 8px">epump2_v1</td><td style="padding:4px 8px">epump2</td><td style="padding:4px 8px">HI4B0620</td><td style="padding:4px 8px">HI4B0620_down</td><td style="padding:4px 8px">咬齿</td><td style="padding:4px 8px;color:var(--mut)">（同上）</td></tr>
          </tbody>
        </table>
      </div>
      <p class="hint" style="margin-top:10px">tdms 定位：有数据库文件夹按 (line,sn) 查登记路径(<b>已注册</b>)；否则在源数据文件夹按 <b>line 子目录 + 文件名含 sn</b> find_tdms(<b>未注册</b>)；都找不到为 <b>缺失</b>。</p>
    </div>
  </div>

  <!-- ===== 文件/目录浏览器 ===== -->
  <div v-if="picker.open" class="modal-mask" @click.self="picker.open=false">
    <div class="modal">
      <div class="modal-h">
        {{ picker.target==='export' ? '选择导出目录' : (picker.target==='label' ? '选择数据库文件夹' : (pickerDirMode ? '选择 TDMS 目录' : '选择 CSV 文件')) }}
        <button class="btn" @click="tryNativeDialog" title="尝试系统对话框">系统对话框</button>
        <button class="btn" style="margin-left:auto" @click="picker.open=false">✕</button>
      </div>
      <div class="modal-roots">
        <span class="chip" v-for="r in roots" :key="r.path" @click="browse(r.path)">{{ r.label }}</span>
      </div>
      <div class="modal-path">{{ picker.path || '~' }}</div>
      <div class="modal-list">
        <div class="item" v-if="picker.parent" @click="browse(picker.parent)">📁 ..</div>
        <div class="item" v-for="d in picker.dirs" :key="'d'+d" @click="browse(joinPath(picker.path,d))">📁 {{ d }}</div>
        <template v-if="!pickerDirMode">
          <div class="item file" v-for="f in picker.files" :key="'f'+f" @click="pickFile(f)">📄 {{ f }}</div>
          <div v-if="!picker.dirs.length && !picker.files.length" class="item" style="color:var(--mut)">（此目录无子目录、csv 或 db 文件）</div>
        </template>
      </div>
      <div class="modal-f">
        <button v-if="pickerDirMode" class="btn primary" @click="pickDir()">
          {{ picker.target==='export' ? '导出到此目录' : '选择此目录' }}
        </button>
        <span class="hint">{{ pickerDirMode ? '进入目标目录后点下方按钮' : '点击 csv 文件即选中' }}</span>
      </div>
    </div>
  </div>


  <!-- ===== 列表总览 ===== -->
  <div v-show="view==='list'" class="wrap">
    <div class="toolbar">
      <label>标注状态
        <select v-model="filters.status" @change="applyFilters">
          <option value="all">全部</option><option value="labeled">已标注</option><option value="unlabeled">未标注</option>
        </select>
      </label>
      <label>线名
        <select v-model="filters.line" @change="applyFilters">
          <option value="all">全部</option>
          <option v-for="l in lines" :key="l" :value="l">{{ l }}</option>
        </select>
      </label>
      <label><input type="checkbox" v-model="filters.typicalOnly" @change="applyFilters" /> 仅典型异音 ★</label>
      <label><input type="checkbox" v-model="filters.missingTdms" @change="applyFilters" /> 仅 tdms 缺失</label>
      <button class="btn" @click="reload">↻ 刷新</button>
      <span class="stats">共 <b>{{ stats.total }}</b> · 已标 <b>{{ stats.labeled }}</b> · 未标 <b>{{ stats.unlabeled }}</b> · 典型 <b>{{ stats.typical }}</b> · tdms 已注册 <b>{{ stats.registered }}</b>/未注册 <b>{{ stats.unregistered }}</b>/缺失 <b>{{ stats.unresolved }}</b></span>
    </div>
    <div id="grid" class="ag-theme-quartz"></div>
    <div class="hint">双击任意一行 → 进入该样本的标注视图。表头可排序、按列筛选。</div>
  </div>

  <!-- ===== 逐条标注（按 SN 分组，组内 up/down 并列）===== -->
  <div v-show="view==='label'">
    <div class="navbar">
      <button class="btn" @click="view='list'">← 列表</button>
      <button class="btn" :disabled="snPos<=0" @click="prevGroup">⬅ 上一条</button>
      <div class="progress">
        <div class="lab">标注进度 {{ stats.labeled }}/{{ stats.total }}（{{ pct }}%） · SN {{ snPos+1 }}/{{ snList.length }}</div>
        <div class="bar"><i :style="{width: pct+'%'}"></i></div>
      </div>
      <button class="btn" :disabled="snPos>=snList.length-1" @click="nextGroup">下一条 ➡</button>
      <button class="btn" @click="openExport">⬇ 导出标签</button>
    </div>

    <template v-if="channels.length">
      <div class="meta">
        <div><span class="k">SN</span><b>{{ currentSn }}</b></div>
        <div><span class="k">line</span>{{ channels[0].row.line || '—' }}</div>
        <div><span class="k">通道</span>{{ channels.length }}（{{ channels.map(c=>c.direction).join(' / ') }}）</div>
        <span v-if="opMsg" :style="{color: opErr?'#b91c1c':'var(--mut)', fontSize:'13px'}">{{ opMsg }}</span>
      </div>

      <!-- 通道并列 -->
      <div class="channels-row">
        <div class="channel-col" v-for="ch in channels" :key="ch.index">
          <div class="ch-head">
            {{ ch.direction==='down' ? '⬇' : '⬆' }} {{ ch.sample_id }}
            <span v-if="ch.row.labeled" class="tag ok">已标注 · {{ ch.row.reason_name }}</span>
            <span v-else class="tag">未标注</span>
            <span v-if="ch.row.typical" class="tag star">★典型</span>
          </div>

          <div v-if="ch.loading" class="loading">加载 tdms / 生成曲线频谱…</div>
          <template v-else>
            <div class="card" v-if="ch.audioUrl">
              <div class="card-h">🔊 播放器</div>
              <div style="padding:6px 12px"><audio :src="ch.audioUrl" controls preload="none" style="width:100%"></audio></div>
            </div>
            <div class="card" v-for="card in ch.cards" :key="card.id">
              <div class="card-h">{{ cardIcon(card) }} {{ card.title }}</div>
              <div v-if="card.error" style="padding:12px;color:#b91c1c">渲染失败: {{ card.error }}</div>
              <div v-else class="plot" :id="'plot-'+ch.index+'-'+card.id"></div>
            </div>

            <!-- 标注 -->
            <div class="card">
              <div class="card-h">📝 标注</div>
              <div style="padding:12px">
                <button v-if="!ch.labelForm.open" class="btn primary" @click="ch.labelForm.open=true">开始新的标注</button>
                <div v-else>
                  <div class="field">
                    <label>原因 reason</label>
                    <select v-model="ch.labelForm.reason_key" style="width:100%;padding:7px 10px;border:1px solid var(--bd);border-radius:7px">
                      <option v-for="r in reasons" :key="r.key" :value="r.key">{{ r.name }}（{{ r.key }}）</option>
                    </select>
                  </div>
                  <div class="field">
                    <label>置信度</label>
                    <span v-for="(v,k) in confidenceOptions" :key="k" style="margin-right:14px;font-size:13px">
                      <input type="radio" :value="v" v-model="ch.labelForm.confidence" /> {{ k }}
                    </span>
                  </div>
                  <div class="field">
                    <label>备注 note</label>
                    <input type="text" v-model="ch.labelForm.note" placeholder="其他/边界/不确定请说明"
                           style="width:100%;padding:7px 10px;border:1px solid var(--bd);border-radius:7px" />
                  </div>
                  <div style="display:flex;gap:10px;margin-top:8px">
                    <button class="btn primary" @click="saveLabel(ch)" :disabled="ch.saving">{{ ch.saving?'保存中…':'保存标注' }}</button>
                    <button class="btn" @click="ch.labelForm.open=false">取消</button>
                  </div>
                </div>
                <div style="margin-top:12px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                  <button class="btn" @click="markTypical(ch, !ch.row.typical)">
                    {{ ch.row.typical ? '✓ 取消典型异音' : '★ 标记为典型异音' }}
                  </button>
                  <span v-if="ch.msg" :style="{color: ch.err?'#b91c1c':'var(--mut)', fontSize:'13px'}">{{ ch.msg }}</span>
                </div>
              </div>
            </div>

            <!-- label_history -->
            <div class="card">
              <div class="card-h">🕘 label_history（{{ ch.history.length }}）</div>
              <div style="padding:6px 12px;overflow:auto">
                <table style="width:100%;border-collapse:collapse;font-size:12px">
                  <thead><tr style="text-align:left;color:var(--mut)">
                    <th style="padding:4px 6px">timestamp</th><th>source</th><th>reason</th><th>conf</th><th>note</th>
                    <th v-if="hasDb">操作</th>
                  </tr></thead>
                  <tbody>
                    <tr v-for="(h,i) in ch.history" :key="i" style="border-top:1px solid var(--bd)">
                      <td style="padding:4px 6px">{{ h.timestamp }}</td><td>{{ h.source }}</td>
                      <td>{{ h.reason_name }}</td><td>{{ h.reason_confidence }}</td><td>{{ h.note }}</td>
                      <td v-if="hasDb" style="white-space:nowrap">
                        <select v-model="h._src" style="font-size:11px;padding:1px 4px;border:1px solid var(--bd);border-radius:5px">
                          <option v-for="src in sources" :key="src" :value="src">{{ src }}</option>
                        </select>
                        <button class="btn" style="padding:1px 7px;margin:0 4px" @click="confirmLabel(ch,i,h._src)">确认正确</button>
                        <button class="btn" style="padding:1px 7px" @click="deleteLabel(ch,i)">删除</button>
                      </td>
                    </tr>
                    <tr v-if="!ch.history.length"><td :colspan="hasDb?6:5" style="padding:8px;color:var(--mut)">暂无记录</td></tr>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- 任务结果 / 建议 -->
            <div class="card" v-if="ch.taskResults.length || ch.suggestions.length">
              <div class="card-h">🛠 任务结果 / 建议</div>
              <div style="padding:8px 12px;font-size:13px">
                <div v-for="(t,i) in ch.taskResults" :key="'r'+i" style="margin-bottom:4px">
                  <span style="color:var(--mut)">{{ t.task_title }}：</span>
                  <span v-for="(v,k) in t.data" :key="k" style="margin-right:10px">{{ k }}=<b>{{ v }}</b></span>
                </div>
                <div v-for="(sug,i) in ch.suggestions" :key="'s'+i" style="margin-top:6px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                  <span class="tag">建议</span>
                  <span>{{ sug.task_title }} → <b>{{ sug.reason_key }}</b>（{{ sug.confidence }}）</span>
                  <button v-if="!sug.accepted" class="btn" @click="acceptSuggestion(ch, sug)">采纳</button>
                  <span v-else class="tag ok">已采纳</span>
                </div>
              </div>
            </div>

            <!-- 高级频谱分析：按行按钮，点击展开内容（在 label_history 下方）-->
            <div class="card">
              <div class="card-h">🧩 高级频谱分析</div>
              <div style="padding:10px 12px;display:flex;gap:8px;flex-wrap:wrap">
                <button v-for="ic in insertable" :key="ic.id" class="btn"
                        :class="{primary: isAdvShown(ch, ic.id)}" @click="toggleCard(ch, ic.id)">
                  {{ ic.title }}
                </button>
              </div>
              <!-- 展开的高级频谱内容（按卡片顺序，放在最下面）-->
              <div v-for="card in ch.advCards" :key="card.id" style="border-top:1px solid var(--bd)">
                <div class="card-h" style="display:flex;align-items:center;gap:6px;background:#fff">
                  <span>{{ cardIcon(card) }} {{ card.title }}</span>
                  <button class="btn" style="margin-left:auto;padding:1px 8px" @click="toggleCard(ch, card.id)">✕</button>
                </div>
                <div v-if="card.params && card.params.length" class="param-panel">
                  <div class="param-panel-h">⚙ 参数调整</div>
                  <div class="param-grid">
                    <label v-for="p in card.params" :key="p.key" class="param-item">
                      <span>{{ p.label }}</span>
                      <select v-if="p.type==='select'" v-model="card.values[p.key]" @change="applyCardParams(ch,card)">
                        <option v-for="o in p.options" :key="o" :value="o">{{ o }}</option>
                      </select>
                      <input v-else type="number" v-model.number="card.values[p.key]" :min="p.min" :max="p.max" :step="p.step"
                             @change="applyCardParams(ch,card)" />
                    </label>
                    <button class="btn" style="align-self:end" @click="resetCardParams(ch,card)">重置</button>
                  </div>
                </div>
                <div v-if="card.loading" class="loading">渲染中…</div>
                <div v-else-if="card.error" style="padding:12px;color:#b91c1c">渲染失败: {{ card.error }}</div>
                <div v-else class="plot full" :id="'plot-'+ch.index+'-'+card.id"></div>
              </div>
            </div>
          </template>
        </div>
      </div>
    </template>
    <p v-else style="color:var(--mut); padding:18px">从列表双击一行进入。</p>
  </div>
</div>

<script>
const { createApp, reactive, toRefs, computed, nextTick } = Vue;

createApp({
  setup() {
    const state = reactive({
      view: 'init', allRows: [], lines: [],
      stats: { total: 0, labeled: 0, unlabeled: 0, typical: 0 },
      isMock: false,
      filters: { status:'all', line:'all', typicalOnly:false, missingTdms:false },
      currentSn: '', channels: [],
      initForm: { sample_view_path:'', tdms_root:'', loadLabels:false, sample_records_db_path:'', source:'expert' },
      initing: false, initMsg: '', initErr: false, dragTarget: '',
      sources: ['expert','operator'], hasDb: false,
      picker: { open:false, target:'', path:'', parent:'', dirs:[], files:[] }, roots: [],
      reasons: [], confidenceOptions: {},
      insertable: [],
      taskTypes: [], taskForm: { task_id:'', scope:'all', params:{} }, runs: [],
      opMsg:'', opErr:false,
    });
    let gridApi = null;

    // ---- 文件浏览器（浏览后端本机文件系统，本地/远程都可用）----
    function joinPath(base, name){ return base ? (base.replace(/\/$/,'') + '/' + name) : name; }
    function applyPicked(path){
      const t = state.picker.target;
      if (t==='sv') state.initForm.sample_view_path = path;
      else if (t==='label') state.initForm.sample_records_db_path = path;
      else state.initForm.tdms_root = path;
    }
    async function browse(path){
      try {
        const r = await fetch('/api/browse?path='+encodeURIComponent(path||''));
        const d = await r.json();
        if(!r.ok){ state.initErr=true; state.initMsg=d.detail||'无法读取目录'; return; }
        Object.assign(state.picker, { path:d.path, parent:d.parent, dirs:d.dirs, files:d.files });
      } catch(e){ state.initErr=true; state.initMsg=String(e); }
    }
    const pickerDirMode = computed(() => ['tdms','export','label'].includes(state.picker.target));

    async function openPickerModal(target){
      state.initMsg=''; state.initErr=false; state.opMsg='';
      state.picker.open = true; state.picker.target = target;
      if (!state.roots.length) {
        try { state.roots = (await fetch('/api/roots').then(x=>x.json())).roots || []; } catch(e){}
      }
      let cur = target==='sv' ? state.initForm.sample_view_path
              : target==='label' ? state.initForm.sample_records_db_path
              : target==='tdms' ? state.initForm.tdms_root
              : state.initForm.sample_view_path;  // export 从 sample_view 目录起步
      await browse(cur ? cur.replace(/\/[^/]*$/,'') : '');
    }
    // 文件选择（csv）走网页浏览器；目录选择直接弹系统原生对话框
    function openPicker(target){ openPickerModal(target); }
    // 目录类（tdms / db数据库文件夹 / export）：直接系统对话框，失败回退网页浏览器
    async function nativeDir(target){
      state.initMsg=''; state.initErr=false; state.opMsg='';
      const curMap = { tdms: state.initForm.tdms_root, label: state.initForm.sample_records_db_path };
      const cur = curMap[target] || state.initForm.sample_view_path;
      const titleMap = { export:'选择导出目录', tdms:'选择 TDMS 目录', label:'选择数据库文件夹' };
      try {
        const r = await fetch(`/api/pick?kind=dir&title=${encodeURIComponent(titleMap[target]||'选择目录')}&initial=${encodeURIComponent(cur?cur.replace(/\/[^/]*$/,''):'')}`);
        const d = await r.json();
        if(!r.ok) throw new Error(d.detail||'系统对话框不可用');
        if(d.canceled || !d.path) return;
        if(target==='export'){ await doExport(d.path); }
        else if(target==='label'){ state.initForm.sample_records_db_path = d.path; }
        else { state.initForm.tdms_root = d.path; }
      } catch(e){
        openPickerModal(target);   // 无 GUI 回退网页文件浏览器
      }
    }
    function openExport(){ nativeDir('export'); }

    // ---- 拖拽文件/文件夹 ----
    function setField(target, path){
      if(target==='sv') state.initForm.sample_view_path = path;
      else if(target==='label') state.initForm.sample_records_db_path = path;
      else state.initForm.tdms_root = path;
    }
    async function onDrop(e, target){
      state.dragTarget=''; state.initMsg=''; state.initErr=false;
      const dt = e.dataTransfer;
      const f = dt.files && dt.files[0];
      // ① 浏览器若暴露绝对路径（桌面打包/部分环境）→ 文件或文件夹都能直接用
      if (f && f.path){ setField(target, f.path); state.initMsg='已读取拖入路径'; return; }
      // ② 文件夹：普通浏览器拿不到路径
      const item = dt.items && dt.items[0];
      const entry = item && item.webkitGetAsEntry && item.webkitGetAsEntry();
      if (entry && entry.isDirectory){
        state.initErr=true; state.initMsg='浏览器无法获取文件夹路径，请点"选择…"用系统对话框'; return;
      }
      if (target==='tdms'){
        state.initErr=true; state.initMsg='TDMS 需要目录，请拖文件夹或点"选择…"'; return;
      }
      // ③ CSV 文件：上传内容，后端存一份并回填路径
      if (!f){ return; }
      try {
        const fd = new FormData(); fd.append('file', f, f.name);
        const r = await fetch('/api/upload',{method:'POST', body:fd});
        const d = await r.json();
        if(!r.ok){ state.initErr=true; state.initMsg=d.detail||'上传失败'; return; }
        setField(target, d.path);
        state.initMsg=`已上传 ${d.name}`;
      } catch(err){ state.initErr=true; state.initMsg='上传失败: '+err; }
    }
    function pickFile(name){ applyPicked(joinPath(state.picker.path, name)); state.picker.open=false; }
    async function pickDir(){
      if (state.picker.target==='export') { await doExport(state.picker.path); state.picker.open=false; return; }
      applyPicked(state.picker.path); state.picker.open=false;
    }
    async function doExport(dir){
      state.opMsg=''; state.opErr=false;
      try {
        const r = await fetch('/api/export',{method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({out_path: dir})});
        const d = await r.json();
        if(!r.ok){ state.opErr=true; state.opMsg=d.detail||'导出失败'; return; }
        state.opMsg = `已导出 ${d.rows} 条到 ${d.path}`;
      } catch(e){ state.opErr=true; state.opMsg=String(e); }
    }
    // 可选：尝试后端本机的系统原生对话框（仅本地 GUI 有效）
    async function tryNativeDialog(){
      const kind = state.picker.target==='tdms' ? 'dir' : 'file';
      try {
        const r = await fetch(`/api/pick?kind=${kind}`);
        const d = await r.json();
        if(!r.ok){ state.initErr=true; state.initMsg=(d.detail||'系统对话框不可用')+'，请用上方文件浏览器'; return; }
        if(d.canceled || !d.path) return;
        applyPicked(d.path); state.picker.open=false;
      } catch(e){ state.initErr=true; state.initMsg='系统对话框不可用，请用上方文件浏览器'; }
    }
    async function doInit(){
      state.initing = true; state.initMsg=''; state.initErr=false;
      try {
        const body = {
          sample_view_path: state.initForm.sample_view_path,
          tdms_root: state.initForm.tdms_root,
          sample_records_db_path: state.initForm.loadLabels ? state.initForm.sample_records_db_path : '',
          source: state.initForm.source,
        };
        const r = await fetch('/api/init',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        const d = await r.json();
        if(!r.ok){ state.initErr=true; state.initMsg = d.detail || '初始化失败'; return; }
        state.initMsg = `已加载 ${d.n_samples} 条样本，解析到 ${d.n_resolved} 个 tdms` + (d.n_unresolved? `，${d.n_unresolved} 个未解析`:'');
        await reload();
        state.currentSn = ''; state.channels = [];
        state.view = 'list';
      } catch(e){ state.initErr=true; state.initMsg = String(e); }
      finally { state.initing = false; }
    }

    const pct = computed(() => state.stats.total ? Math.round(state.stats.labeled / state.stats.total * 100) : 0);

    const columnDefs = [
      { headerName:'#', field:'index', width:80, filter:'agNumberColumnFilter' },
      { headerName:'sn', field:'sn', width:130, filter:true },
      { headerName:'sample_id', field:'sample_id', width:160, filter:true },
      { headerName:'line', field:'line', width:100, filter:true },
      { headerName:'输入', field:'is_input', width:78, filter:true,
        valueFormatter:p=>p.value?'✓ 输入':'补全' },
      { headerName:'已标注', field:'labeled', width:90, valueFormatter:p=>p.value?'✅':'—' },
      { headerName:'reason', field:'reason_name', width:120, filter:true },
      { headerName:'置信度', field:'reason_confidence', width:90 },
      { headerName:'来源', field:'source', width:90, filter:true },
      { headerName:'典型', field:'typical', width:80, valueFormatter:p=>p.value?'★':'' },
      { headerName:'note', field:'note', flex:1, minWidth:160, filter:true },
      { headerName:'tdms', field:'tdms', width:90 },
    ];

    function visibleRows() {
      const f = state.filters;
      return state.allRows.filter(r => {
        if (f.status==='labeled' && !r.labeled) return false;
        if (f.status==='unlabeled' && r.labeled) return false;
        if (f.line!=='all' && r.line!==f.line) return false;
        if (f.typicalOnly && !r.typical) return false;
        if (f.missingTdms && r.tdms!=='缺失') return false;
        return true;
      });
    }
    function applyFilters(){ if(gridApi) gridApi.setGridOption('rowData', visibleRows()); }

    function cardIcon(c){ return c.category==='waveform' ? '📈' : (c.category==='spectrum' ? '🌈' : '🧩'); }

    // ---- SN 分组导航 ----
    const snList = computed(() => {
      const seen = new Set(), out = [];
      for (const r of state.allRows){ if(!seen.has(r.sn)){ seen.add(r.sn); out.push(r.sn); } }
      return out;
    });
    const snPos = computed(() => snList.value.indexOf(state.currentSn));

    function dirOf(sid){ return String(sid).toLowerCase().endsWith('_down') ? 'down' : 'up'; }
    function defaultReason(){ return state.reasons.length ? state.reasons[0].key : ''; }

    function makeChannel(row){
      return { index:row.index, sample_id:row.sample_id, direction:dirOf(row.sample_id),
               row, cards:[], audioUrl:'', loading:true, history:[], advCards:[],
               taskResults:[], suggestions:[],
               labelForm:{open:false, reason_key:defaultReason(), confidence:0.9, note:''},
               saving:false, msg:'', err:false };
    }

    function isAdvShown(ch, cid){ return ch.advCards.some(c=>c.id===cid); }
    function advOrder(cid){ return state.insertable.findIndex(ic=>ic.id===cid); }
    async function toggleCard(ch, cid){
      if (isAdvShown(ch, cid)){
        const el = document.getElementById('plot-'+ch.index+'-'+cid);
        if(el && window.Plotly) Plotly.purge(el);
        ch.advCards = ch.advCards.filter(c=>c.id!==cid);
        return;
      }
      const spec = state.insertable.find(ic=>ic.id===cid) || {};
      const values = {};
      (spec.params||[]).forEach(p=> values[p.key]=p.default);
      const placeholder = { id:cid, title:spec.title||cid, removable:true, loading:true,
                            params:spec.params||[], values, figure:null };
      ch.advCards.push(placeholder);
      ch.advCards.sort((a,b)=>advOrder(a.id)-advOrder(b.id));
      await fetchCard(ch, placeholder);
    }

    async function fetchCard(ch, card){
      card.loading = true;
      try {
        const d = await fetch(`/api/sample/${ch.index}/card`,{method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({card_id:card.id, params:card.values})}).then(x=>x.json());
        const res = d.card || {};
        card.figure = res.figure; card.error = res.error;
      } catch(e){ card.error = String(e); }
      card.loading = false;
      renderPlots();
    }
    function applyCardParams(ch, card){ fetchCard(ch, card); }
    function resetCardParams(ch, card){
      (card.params||[]).forEach(p=> card.values[p.key]=p.default);
      fetchCard(ch, card);
    }

    function drawCard(ch, card){
      if (card.error || !card.figure) return;
      const el = document.getElementById('plot-'+ch.index+'-'+card.id);
      if (!el) return;
      const base = card.figure.layout || {};
      const layout = Object.assign({}, base, {autosize:true});
      layout.title = '';                      // 删除图标题（Time / Mel Spectrogram 等）
      if (card.removable) {
        layout.height = base.height || 460;   // 高级频谱：完整尺寸
      } else {
        layout.height = 240;                  // 默认曲线：固定高度，去标题后主图更大
        layout.margin = {l:46, r:12, t:8, b:30};
      }
      Plotly.react(el, card.figure.data||[], layout, {responsive:true, displaylogo:false});
    }
    async function renderPlots(){
      await nextTick();
      for (const ch of state.channels){
        for (const card of ch.cards) drawCard(ch, card);
        for (const card of ch.advCards) drawCard(ch, card);
      }
    }

    async function reloadHistory(ch){
      try {
        const list = (await fetch(`/api/sample/${ch.index}/history`).then(x=>x.json())).history || [];
        list.forEach(h=> h._src = h.source || state.initForm.source || 'expert');
        ch.history = list;
      } catch(e){ ch.history = []; }
    }
    async function confirmLabel(ch, i, source){
      const r = await fetch('/api/label/confirm',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({index:ch.index, event_index:i, source})});
      const d = await r.json();
      if(!r.ok){ ch.err=true; ch.msg=d.detail||'确认失败'; return; }
      ch.msg='已确认（source='+d.source+'）';
      await reloadHistory(ch); await refreshRows();
    }
    async function deleteLabel(ch, i){
      const r = await fetch('/api/label/delete',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({index:ch.index, event_index:i})});
      const d = await r.json();
      if(!r.ok){ ch.err=true; ch.msg=d.detail||'删除失败'; return; }
      ch.msg='已删除一条标注';
      await reloadHistory(ch); await refreshRows();
    }

    async function loadChannel(ch){
      ch.loading = true; ch.cards = []; ch.audioUrl = '';
      await reloadHistory(ch);
      loadChannelTasks(ch);
      try {
        const d = await fetch(`/api/sample/${ch.index}/cards`).then(x=>x.json());
        ch.cards = d.cards || [];
        ch.audioUrl = `/api/sample/${ch.index}/audio.wav?t=${Date.now()}`;
      } catch(e){ ch.cards = []; }
      ch.loading = false;
    }
    async function loadChannelTasks(ch){
      try {
        const d = await fetch(`/api/sample/${ch.index}/tasks`).then(x=>x.json());
        ch.taskResults = d.results || []; ch.suggestions = d.suggestions || [];
      } catch(e){ ch.taskResults = []; ch.suggestions = []; }
    }
    async function acceptSuggestion(ch, sug){
      const r = await fetch('/api/tasks/accept',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({run_id:sug.run_id, sample_id:ch.sample_id})});
      const d = await r.json();
      if(!r.ok){ ch.err=true; ch.msg=d.detail||'采纳失败'; return; }
      sug.accepted = true;
      ch.history = (await fetch(`/api/sample/${ch.index}/history`).then(x=>x.json())).history || [];
      await refreshRows();
    }

    // ---- 任务视图 ----
    const currentTaskParams = computed(() => {
      const t = state.taskTypes.find(t=>t.id===state.taskForm.task_id);
      return t ? (t.params||[]) : [];
    });
    function onTaskTypeChange(){
      const params = {};
      currentTaskParams.value.forEach(p=> params[p.key]=p.default);
      state.taskForm.params = params;
    }
    async function openTasks(){
      state.view='task';
      if(!state.taskTypes.length){
        state.taskTypes = (await fetch('/api/tasks').then(x=>x.json())).tasks || [];
        if(state.taskTypes.length){ state.taskForm.task_id = state.taskTypes[0].id; onTaskTypeChange(); }
      }
      loadRuns();
    }
    let runPollTimer = null;
    async function loadRuns(){
      state.runs = (await fetch('/api/tasks/runs').then(x=>x.json())).runs || [];
      const anyRunning = state.runs.some(r=>r.status==='running'||r.status==='pending');
      if(anyRunning && !runPollTimer){ runPollTimer = setInterval(loadRuns, 1000); }
      if(!anyRunning && runPollTimer){ clearInterval(runPollTimer); runPollTimer=null; }
    }
    async function runTask(){
      const r = await fetch('/api/tasks/run',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({task_id:state.taskForm.task_id, scope:state.taskForm.scope, params:state.taskForm.params})});
      await loadRuns();
    }

    async function loadGroup(sn){
      state.currentSn = sn; state.opMsg='';
      state.channels = state.allRows.filter(r => r.sn === sn).map(makeChannel);
      await Promise.all(state.channels.map(loadChannel));
      renderPlots();
    }

    function goto(index){
      const row = state.allRows[index];
      if (!row) return;
      state.view = 'label';
      loadGroup(row.sn);
    }
    function prevGroup(){ const i=snPos.value; if(i>0) loadGroup(snList.value[i-1]); }
    function nextGroup(){ const i=snPos.value; if(i<snList.value.length-1) loadGroup(snList.value[i+1]); }

    // 写操作后：刷新总览并把当前组的 row 引用更新（保留卡片不重渲染）
    async function refreshRows(){
      const d = await fetch('/api/overview').then(x=>x.json());
      state.allRows=d.rows; state.lines=d.lines; state.stats=d.stats; state.isMock=d.is_mock;
      if(gridApi) applyFilters();
      const byId = Object.fromEntries(state.allRows.map(r=>[r.sample_id, r]));
      for (const ch of state.channels){ if(byId[ch.sample_id]) ch.row = byId[ch.sample_id]; }
    }

    async function saveLabel(ch){
      if (!ch.labelForm.reason_key){ ch.err=true; ch.msg='请选择 reason'; return; }
      ch.saving=true; ch.msg=''; ch.err=false;
      try {
        const r = await fetch('/api/label',{method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({index:ch.index, reason_key:ch.labelForm.reason_key,
            reason_confidence:ch.labelForm.confidence, note:ch.labelForm.note})});
        const d = await r.json();
        if(!r.ok){ ch.err=true; ch.msg=d.detail||'保存失败'; return; }
        ch.msg='已保存'; ch.labelForm.open=false; ch.labelForm.note='';
        ch.history = (await fetch(`/api/sample/${ch.index}/history`).then(x=>x.json())).history || [];
        await refreshRows();
      } catch(e){ ch.err=true; ch.msg=String(e); }
      finally { ch.saving=false; }
    }

    async function markTypical(ch, flag){
      ch.msg=''; ch.err=false;
      const r = await fetch('/api/typical',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({index:ch.index, flag})});
      const d = await r.json();
      if(!r.ok){ ch.err=true; ch.msg=d.detail||'操作失败'; return; }
      ch.msg = flag?'已标记典型异音':'已取消典型异音';
      ch.history = (await fetch(`/api/sample/${ch.index}/history`).then(x=>x.json())).history || [];
      await refreshRows();
    }

    function initGrid(){
      gridApi = agGrid.createGrid(document.getElementById('grid'), {
        columnDefs, rowData: visibleRows(),
        defaultColDef:{ resizable:true, sortable:true },
        rowSelection:'single',
        onRowDoubleClicked: e => goto(e.data.index),
      });
    }

    async function reload(){
      const d = await fetch('/api/overview').then(x=>x.json());
      state.allRows=d.rows; state.lines=d.lines; state.stats=d.stats; state.isMock=d.is_mock;
      state.hasDb = !!d.has_db;
      if(gridApi) applyFilters(); else initGrid();
    }

    Vue.onMounted(async () => {
      const rs = await fetch('/api/reasons').then(x=>x.json());
      state.reasons = rs.reasons || []; state.confidenceOptions = rs.confidence_options || {};
      try {
        const cd = await fetch('/api/cards').then(x=>x.json());
        const def = new Set(cd.default||[]);
        state.insertable = (cd.cards||[]).filter(c=>!def.has(c.id))
          .map(c=>({id:c.id, title:c.title, params:c.params||[]}));
      } catch(e){}
      const cfg = await fetch('/api/config').then(x=>x.json());
      if (!cfg.is_mock && cfg.n_samples > 0) { await reload(); state.view = 'list'; }
    });
    return { ...toRefs(state), pct, snList, snPos, pickerDirMode, currentTaskParams,
             applyFilters, reload, goto, cardIcon,
             prevGroup, nextGroup, isAdvShown, toggleCard, applyCardParams, resetCardParams, acceptSuggestion,
             onDrop, openPicker, openPickerModal, nativeDir, openExport, browse, joinPath, pickFile, pickDir,
             openTasks, onTaskTypeChange, loadRuns, runTask,
             tryNativeDialog, doInit, saveLabel, markTypical };
  }
}).mount('#app');
</script>
</body>
</html>
